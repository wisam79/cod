{
  "name": "mohemmaty-server",
  "version": "1.0.0",
  "description": "Backend API server for Mohemmaty App with SQLite, Sequelize, JWT, WebSockets, and Security protections.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles --forceExit"
  },
  "keywords": [
    "express",
    "sqlite3",
    "sequelize",
    "websocket",
    "jwt",
    "security"
  ],
  "author": "Backend Specialist",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "sqlite3": "^5.1.7",
    "winston": "^3.13.0",
    "ws": "^8.16.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
